@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Team Performance Predictor</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: #0B1437;
            min-height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* Left panel — branding */
        .left-panel {
            flex: 1;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
            overflow: hidden;
        }

        /* Animated orbs background */
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: .35;
            animation: float 8s ease-in-out infinite;
        }
        .orb-1 { width: 400px; height: 400px; background: #00C9A7; top: -100px; left: -100px; animation-delay: 0s; }
        .orb-2 { width: 300px; height: 300px; background: #0055FF; bottom: -50px; right: -50px; animation-delay: -4s; }
        .orb-3 { width: 200px; height: 200px; background: #8B5CF6; top: 50%; left: 40%; animation-delay: -2s; }

       @@keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(20px, -30px) scale(1.05); }
    66%       { transform: translate(-15px, 20px) scale(.95); }
}

        .left-content { position: relative; z-index: 2; }

        .brand-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(0,201,167,.15); border: 1px solid rgba(0,201,167,.3);
            padding: 6px 14px; border-radius: 20px; margin-bottom: 32px;
        }
        .brand-badge span { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: #00C9A7; }

        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: 48px; font-weight: 800; line-height: 1.1;
            color: #fff; margin-bottom: 20px;
        }
        .hero-title em { font-style: normal; color: #00C9A7; }

        .hero-desc { font-size: 16px; color: rgba(255,255,255,.5); line-height: 1.7; max-width: 440px; }

        .feature-list { margin-top: 40px; display: flex; flex-direction: column; gap: 14px; }
        .feature-item {
            display: flex; align-items: center; gap: 12px;
            font-size: 14px; color: rgba(255,255,255,.65);
        }
        .feature-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: #00C9A7; flex-shrink: 0;
        }

        /* Right panel — login form */
        .right-panel {
            width: 480px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 48px;
            flex-direction: column;
        }

        .form-header { text-align: center; margin-bottom: 36px; width: 100%; }
        .form-header h2 {
            font-family: 'Syne', sans-serif; font-size: 26px; font-weight: 800;
            color: #0B1437; margin-bottom: 6px;
        }
        .form-header p { font-size: 14px; color: #A3AED0; }

        .form-group { margin-bottom: 20px; width: 100%; }
        .form-label { font-size: 12px; font-weight: 700; letter-spacing: .5px; color: #A3AED0; text-transform: uppercase; display: block; margin-bottom: 7px; }
        .form-input {
            width: 100%; padding: 13px 16px; font-size: 15px;
            border: 2px solid #E9EDF7; border-radius: 12px;
            color: #0B1437; outline: none;
            transition: border-color .2s, box-shadow .2s;
            font-family: 'DM Sans', sans-serif;
        }
        .form-input:focus { border-color: #00C9A7; box-shadow: 0 0 0 4px rgba(0,201,167,.1); }

        .input-icon-wrap { position: relative; }
        .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #C4C4C4; font-size: 15px; }
        .form-input.with-icon { padding-left: 42px; }

        .login-btn {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, #00C9A7, #0055FF);
            color: #fff; font-size: 15px; font-weight: 700;
            border: none; border-radius: 12px; cursor: pointer;
            font-family: 'Syne', sans-serif; letter-spacing: .5px;
            transition: opacity .2s, transform .15s;
            margin-top: 8px;
        }
        .login-btn:hover { opacity: .92; transform: translateY(-1px); }
        .login-btn:active { transform: translateY(0); }

        .hint-box {
            margin-top: 24px; padding: 14px 16px;
            background: #F4F7FE; border-radius: 10px;
            font-size: 12.5px; color: #A3AED0; width: 100%; text-align: center;
            line-height: 1.8;
        }
        .hint-box strong { color: #1B2559; }

        .error-box {
            background: rgba(255,92,108,.08); border: 1.5px solid rgba(255,92,108,.3);
            color: #c0392b; border-radius: 10px; padding: 12px 16px;
            font-size: 13px; margin-bottom: 20px; width: 100%;
            display: flex; align-items: center; gap: 8px;
        }
    </style>
</head>
<body>

<div class="left-panel">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="left-content">
        <div class="brand-badge">
            <i class="fa fa-robot" style="color:#00C9A7;font-size:13px;"></i>
            <span>ML-Powered Analytics</span>
        </div>
        <h1 class="hero-title">
            Predict <em>Performance.</em><br />
            Prevent Burnout.
        </h1>
        <p class="hero-desc">
            An intelligent HR analytics platform that uses machine learning
            to monitor team productivity and detect burnout risk before it's too late.
        </p>
        <div class="feature-list">
            <div class="feature-item"><div class="feature-dot"></div> ML.NET FastTree regression for productivity scoring</div>
            <div class="feature-item"><div class="feature-dot"></div> SDCA multi-class classification for burnout risk</div>
            <div class="feature-item"><div class="feature-dot"></div> Real-time team analytics dashboard with Chart.js</div>
            <div class="feature-item"><div class="feature-dot"></div> Role-based access control with JWT authentication</div>
        </div>
    </div>
</div>

<div class="right-panel">
    <div class="form-header">
        <h2>Welcome back</h2>
        <p>Sign in to access your analytics dashboard</p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="error-box"><i class="fa fa-exclamation-circle"></i> @ViewBag.Error</div>
    }

    <form method="post" action="/Auth/Login" style="width:100%;">
        <div class="form-group">
            <label class="form-label">Username</label>
            <div class="input-icon-wrap">
                <i class="fa fa-user input-icon"></i>
                <input type="text" name="username" class="form-input with-icon"
                       placeholder="Enter your username" required autocomplete="username" />
            </div>
        </div>
        <div class="form-group">
            <label class="form-label">Password</label>
            <div class="input-icon-wrap">
                <i class="fa fa-lock input-icon"></i>
                <input type="password" name="password" class="form-input with-icon"
                       placeholder="Enter your password" required autocomplete="current-password" />
            </div>
        </div>
        <button type="submit" class="login-btn">
            <i class="fa fa-sign-in-alt me-2"></i> Sign In to Dashboard
        </button>
    </form>

    <div class="hint-box">
        <strong>Demo Credentials</strong><br />
        Admin: <strong>admin</strong> / <strong>Admin@123</strong><br />
        Manager: <strong>manager</strong> / <strong>Manager@123</strong><br />
        HR: <strong>hr</strong> / <strong>HR@123</strong>
    </div>
</div>

</body>
</html>
