@model List<TeamPerformancePredictor.Models.Team>
@{
    ViewData["Title"] = "Teams";
}

<!-- Header -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
    <div>
        <div style="font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--muted); letter-spacing:1px; text-transform:uppercase; margin-bottom:4px;">
            <i class="fa fa-users me-1"></i> Team Management
        </div>
        <div style="font-size:14px; color:var(--muted);">@Model.Count teams total</div>
    </div>
    <a href="/Team/Create" class="btn-tpp-primary">
        <i class="fa fa-plus me-2"></i>Create Team
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:#d1fae5;border:1px solid #6ee7b7;color:#065f46;padding:12px 16px;border-radius:10px;margin-bottom:20px;font-size:13px;font-weight:600;">
        ✅ @TempData["Success"]
    </div>
}

<!-- Teams Grid -->
<div class="row g-3">
    @foreach (var team in Model)
    {
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="stat-card" style="padding:20px;">
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <div style="font-family:'Syne',sans-serif; font-weight:800; font-size:16px; margin-bottom:4px;">
                            @team.TeamName
                        </div>
                        <div style="font-size:12px; color:var(--muted);">
                            <i class="fa fa-users me-1"></i>
                            @(team.Employees?.Count(e => e.IsActive) ?? 0) active employees
                        </div>
                    </div>
                    <form method="post" action="/Team/Delete/@team.Id"
                          onsubmit="return confirm('Delete team @team.TeamName?');">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                style="padding:6px 10px;border-radius:8px;border:1.5px solid #FF5C6C;background:transparent;color:#FF5C6C;font-size:12px;cursor:pointer;">
                            <i class="fa fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>